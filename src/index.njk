---
layout: layouts/base.njk
title: Home
---

<section class="home-intro">
  <p class="home-greeting">hey, I'm</p>
  <h1 class="home-headline">Your Name.</h1>
  <p class="home-bio">
    I write about code, systems, and the messy process of figuring things out.
    Currently building things at <a href="#">Company</a>.
    Sometimes I have opinions.
  </p>
</section>

<section>
  <p class="section-label">Recent writing</p>
  <ul class="post-list">
    {%- for post in collections.posts | reverse %}
    {% if loop.index <= 10 %}
    <li class="post-list-item">
      <div>
        <p class="post-list-title"><a href="{{ post.url }}">{{ post.data.title }}</a></p>
        {% if post.data.excerpt %}
          <p class="post-list-excerpt">{{ post.data.excerpt }}</p>
        {% endif %}
      </div>
      <time class="post-list-date" datetime="{{ post.date | isoDate }}">{{ post.date | readableDate }}</time>
    </li>
    {% endif %}
    {%- endfor %}
  </ul>
</section>
