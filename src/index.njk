---
layout: layouts/base.njk
title: Home
---

<section class="home-intro">
  <p class="home-greeting">Ciao viandante, sono</p>
  <h1 class="home-headline">Gabriele Iacono.</h1>
  <p class="home-bio">
    Provo a scrivere di machine learning, AI, musica. Mi occupo di <a href="https://en.wikipedia.org/wiki/Nonintrusive_load_monitoring">NILM</a> research in <a href="http://tadapower.it">TaDa</a>.
  </p>
</section>

<section>
  <p class="section-label">Recent writing</p>
  <ul class="post-list">
    {%- for post in collections.posts | reverse %}
    {% if loop.index <= 10 %}
    <li class="post-list-item">
      <div>
        <p class="post-list-title"><a href="{{ post.url }}">{{ post.data.title }}</a></p>
        {% if post.data.excerpt %}
          <p class="post-list-excerpt">{{ post.data.excerpt }}</p>
        {% endif %}
      </div>
      <time class="post-list-date" datetime="{{ post.date | isoDate }}">{{ post.date | readableDate }}</time>
    </li>
    {% endif %}
    {%- endfor %}
  </ul>
</section>
