<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ title }} — {{ site.title }}</title>
  <meta name="description" content="{{ description or site.description }}">

  <!-- Fonts: DM Mono for that raw monospace feel + Lora for warm readable prose -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Mono:ital,wght@0,300;0,400;0,500;1,400&family=Lora:ital,wght@0,400;0,500;0,600;1,400;1,500&display=swap" rel="stylesheet">

  <link rel="stylesheet" href="/css/style.css">
  <link rel="alternate" type="application/rss+xml" title="{{ site.title }}" href="/feed.xml">
</head>
<body>

  <header class="site-header">
    <div class="header-inner">
      <a href="/" class="site-logo">{{ site.title }}</a>
      <nav class="site-nav" aria-label="Main navigation">
        <a href="/blog/">writing</a>
        <a href="/about/">about</a>
        <a href="/contact/">contact</a>
      </nav>
    </div>
  </header>

  <main class="site-main">
    {{ content | safe }}
  </main>

  <footer class="site-footer">
    <div class="footer-inner">
      <p class="footer-left">&copy; {{ site.title }} / {{ page.date | readableDate or "2025" }}</p>
      <p class="footer-right">built with <a href="https://www.11ty.dev/" target="_blank" rel="noopener">11ty</a> & stubbornness</p>
    </div>
  </footer>

</body>
</html>
